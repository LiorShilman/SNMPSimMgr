<UserControl x:Class="SNMPSimMgr.Views.MibPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SNMPSimMgr.ViewModels"
             xmlns:views="clr-namespace:SNMPSimMgr.Views">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="DeviceCardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F1A2E" Offset="0"/>
            <GradientStop Color="#14122A" Offset="0.5"/>
            <GradientStop Color="#0E1520" Offset="1"/>
        </LinearGradientBrush>

        <!-- Config input templates -->
        <DataTemplate x:Key="TextInputTemplate">
            <TextBox Text="{Binding CurrentValue, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                     Background="#0E1118" Foreground="#7CB8FF" BorderBrush="#334466"
                     Padding="6,4"/>
        </DataTemplate>
        <DataTemplate x:Key="NumberInputTemplate">
            <TextBox Text="{Binding CurrentValue, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                     Background="#0E1118" Foreground="#7CB8FF" BorderBrush="#334466"
                     Padding="6,4"/>
        </DataTemplate>
        <DataTemplate x:Key="EnumInputTemplate">
            <ComboBox ItemsSource="{Binding Options}"
                      DisplayMemberPath="Label"
                      SelectedValuePath="Value"
                      SelectedValue="{Binding CurrentValue}"
                      FontSize="12" MinWidth="140"/>
        </DataTemplate>
        <DataTemplate x:Key="ToggleInputTemplate">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox IsChecked="{Binding CurrentValue, Converter={x:Static vm:IntToBoolConverter.Instance}}"
                          VerticalAlignment="Center"/>
                <TextBlock Margin="8,0,0,0" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="OFF"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentValue}" Value="1">
                                    <Setter Property="Text" Value="ON"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <views:ConfigFieldTemplateSelector x:Key="ConfigFieldSelector"
            TextTemplate="{StaticResource TextInputTemplate}"
            NumberTemplate="{StaticResource NumberInputTemplate}"
            EnumTemplate="{StaticResource EnumInputTemplate}"
            ToggleTemplate="{StaticResource ToggleInputTemplate}"/>
    </UserControl.Resources>

    <Grid Background="#0E1118">
        <!-- Loading overlay -->
        <Border Background="#CC000000" Panel.ZIndex="10"
                Visibility="{Binding IsPanelLoading, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x23F3;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding PanelStatus}" FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4">
            <StackPanel Margin="8">

                <!-- ═══════════════ DEVICE IDENTITY CARD ═══════════════ -->
                <Border Background="{StaticResource DeviceCardGradient}" CornerRadius="10"
                        Padding="20,16" Margin="0,0,0,10"
                        BorderBrush="#1A2A44" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="{Binding PanelSchema.DeviceName, FallbackValue='Device'}"/>
                            <WrapPanel Margin="0,8,0,0">
                                <ItemsControl ItemsSource="{Binding IdentityFields}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111825" CornerRadius="12" Padding="10,4"
                                                    Margin="0,0,6,6" BorderBrush="#1E2A44" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center">
                                                        <Run Text="{Binding Name, Mode=OneWay,
                                                            Converter={x:Static vm:FriendlyNameConverter.Instance}}"/>
                                                        <Run Text=":  "/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                                               Foreground="#7CB8FF"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Cascadia Code,Consolas,Courier New"
                                                               Text="{Binding CurrentValue, FallbackValue='—'}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                            <Border Background="#0E1A12" CornerRadius="14" Padding="12,6"
                                    BorderBrush="#1A3A2A" BorderThickness="1">
                                <TextBlock FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreenBrush}">
                                    <Run Text="{Binding PanelSchema.TotalFields, Mode=OneWay, FallbackValue=0}"/>
                                    <Run Text=" fields"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════ AUTO-REFRESH BAR ═══════════════ -->
                <Border Background="#111825" CornerRadius="8" Padding="12,8" Margin="0,0,0,10"
                        BorderBrush="#1A2030" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox IsChecked="{Binding AutoRefreshEnabled}" VerticalAlignment="Center"/>
                            <TextBlock Text="Auto-Refresh" FontSize="12" Margin="8,0,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="20,0,0,0"
                                    VerticalAlignment="Center" Opacity="0.8">
                            <TextBlock Text="Interval:" FontSize="11" Margin="0,0,6,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding AutoRefreshInterval, UpdateSourceTrigger=PropertyChanged}"
                                     Width="36" FontSize="11" TextAlignment="Center"
                                     VerticalAlignment="Center" Padding="2"
                                     Background="#0E1118" Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderBrush="#334466"/>
                            <TextBlock Text="sec" FontSize="11" Margin="4,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#333"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AutoRefreshEnabled}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Setter Property="Text" Value="Paused"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AutoRefreshEnabled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                <Setter Property="Text" Value="LIVE"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ═══════════════ MONITORING SECTION ═══════════════ -->
                <Border Background="#111825" CornerRadius="8" Padding="16,14" Margin="0,0,0,10"
                        BorderBrush="#1A2030" BorderThickness="1"
                        Visibility="{Binding MonitorFields.Count, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="&#x1F4CA;"/>
                                <Run Text=" Monitoring"/>
                            </TextBlock>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding MonitorFields.Count, Mode=OneWay}"/>
                                <Run Text=" fields"/>
                            </TextBlock>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding MonitorFields}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="200" Margin="0,0,8,8" CornerRadius="8"
                                            Background="#0E1118" Padding="12,10"
                                            BorderThickness="3,0,0,0" Cursor="Hand">
                                        <Border.Tag>
                                            <Binding Path="DataContext"
                                                     RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                        </Border.Tag>
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="GET — Read value"
                                                          Command="{Binding PlacementTarget.Tag.PanelGetFieldCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="GET" FontWeight="Bold" FontSize="10"
                                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="SET — Write value"
                                                          Command="{Binding PlacementTarget.Tag.PanelSetFieldDialogCommand,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="SET" FontWeight="Bold" FontSize="10"
                                                                   Foreground="{StaticResource AccentOrangeBrush}"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding InputType}" Value="enum">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentGreenBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InputType}" Value="counter">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InputType}" Value="timeticks">
                                                        <Setter Property="BorderBrush" Value="#B388FF"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding InputType}" Value="gauge">
                                                        <Setter Property="BorderBrush" Value="#FF7043"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock FontSize="10" Foreground="#6B7394"
                                                       Text="{Binding Name, Converter={x:Static vm:FriendlyNameConverter.Instance}}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <DockPanel Margin="0,4,0,0">
                                                <TextBlock FontSize="16" FontWeight="Bold"
                                                           Foreground="#7CB8FF"
                                                           FontFamily="Cascadia Code,Consolas,Courier New"
                                                           TextTrimming="CharacterEllipsis"
                                                           Text="{Binding CurrentValue, FallbackValue='—'}"/>
                                                <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                           FontSize="9" Foreground="#6B7394"
                                                           VerticalAlignment="Bottom" Margin="4,0,0,0"
                                                           Text="{Binding Units}" Opacity="0.7"/>
                                            </DockPanel>
                                            <TextBlock FontSize="10" Margin="0,2,0,0"
                                                       Foreground="{StaticResource AccentOrangeBrush}"
                                                       Visibility="{Binding Options, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock.Text>
                                                    <Binding Path="." Converter="{x:Static vm:EnumLabelConverter.Instance}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ CONFIGURATION SECTION ═══════════════ -->
                <Border Background="#111825" CornerRadius="8" Padding="16,14" Margin="0,0,0,10"
                        BorderBrush="#1A2030" BorderThickness="1"
                        Visibility="{Binding ConfigFields.Count, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}">
                                <Run Text="&#x2699;"/>
                                <Run Text=" Configuration"/>
                            </TextBlock>
                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding ConfigFields.Count, Mode=OneWay}"/>
                                <Run Text=" writable"/>
                            </TextBlock>
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding ConfigFields}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0E1118" CornerRadius="6" Padding="12,8"
                                            Margin="0,0,0,6" BorderBrush="#1A2030" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock FontSize="12"
                                                           Foreground="{StaticResource AccentGreenBrush}"
                                                           Text="{Binding Name, Converter={x:Static vm:FriendlyNameConverter.Instance}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Oid}"/>
                                                <Border Background="#182030" CornerRadius="3" Padding="4,1"
                                                        HorizontalAlignment="Left" Margin="0,3,0,0">
                                                    <TextBlock FontSize="9" Foreground="#6B7394"
                                                               Text="{Binding InputType}"/>
                                                </Border>
                                            </StackPanel>

                                            <ContentPresenter Grid.Column="1" Margin="8,0"
                                                              Content="{Binding}"
                                                              ContentTemplateSelector="{StaticResource ConfigFieldSelector}"
                                                              VerticalAlignment="Center"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="GET" Padding="8,4" FontSize="11" Margin="0,0,4,0"
                                                        Command="{Binding DataContext.PanelGetFieldCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#x1F4BE; Save" Padding="12,4"
                                                        FontSize="11" Style="{StaticResource SuccessButton}"
                                                        Command="{Binding DataContext.PanelSetFieldCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══════════════ TABLES SECTION ═══════════════ -->
                <ItemsControl ItemsSource="{Binding PanelTables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#111825" CornerRadius="8" Padding="16,14"
                                    Margin="0,0,0,8" BorderBrush="#1A2030" BorderThickness="1">
                                <Expander IsExpanded="True">
                                    <Expander.Header>
                                        <DockPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}">
                                                <Run Text="&#x1F4CB;"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Name, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Margin="12,0,0,0" FontSize="10"
                                                       Foreground="#6B7394"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding RowCount, Mode=OneWay}"/>
                                                <Run Text=" rows "/>
                                                <Run Text="&#xB7; "/>
                                                <Run Text="{Binding ColumnCount, Mode=OneWay}"/>
                                                <Run Text=" columns"/>
                                            </TextBlock>
                                        </DockPanel>
                                    </Expander.Header>
                                    <DataGrid ItemsSource="{Binding Data}"
                                              AutoGenerateColumns="True"
                                              IsReadOnly="True" BorderThickness="0"
                                              Background="#0E1118" RowBackground="#0E1118"
                                              AlternatingRowBackground="#111825"
                                              HorizontalGridLinesBrush="#1A2030"
                                              GridLinesVisibility="Horizontal"
                                              FontFamily="Cascadia Code,Consolas,Courier New"
                                              FontSize="11" Margin="0,8,0,0"
                                              MaxHeight="350"
                                              CanUserSortColumns="True"
                                              CanUserReorderColumns="True"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              Tag="{Binding}"
                                              MouseDoubleClick="TableDataGrid_MouseDoubleClick"/>
                                </Expander>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ═══════════════ SYSTEM INFO FOOTER ═══════════════ -->
                <Border Background="#111825" CornerRadius="10"
                        Padding="16,12" Margin="0,4,0,0"
                        BorderBrush="#1A2030" BorderThickness="1"
                        Visibility="{Binding SystemInfoItems.Count, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="12" FontWeight="Bold" Margin="0,0,0,10"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="&#x2139;"/>
                            <Run Text=" System Properties"/>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding SystemInfoItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,12,6" Padding="8,4" Background="#0E1118"
                                            CornerRadius="6" BorderBrush="#1A2030" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Category}" Value="identity">
                                                                <Setter Property="Fill" Value="#B388FF"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Category}" Value="network">
                                                                <Setter Property="Fill" Value="{StaticResource AccentBlueBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontSize="10" Foreground="#6B7394"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Label, Mode=OneWay}"/>
                                                <Run Text=": "/>
                                            </TextBlock>
                                            <TextBlock FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#7CB8FF"
                                                       FontFamily="Cascadia Code,Consolas,Courier New"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding Value}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
