<Window x:Class="SNMPSimMgr.Views.UserGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="מדריך למשתמש — SNMP SimManager"
        Width="750" Height="700"
        Background="#1B1F2A"
        WindowStartupLocation="CenterOwner"
        FlowDirection="RightToLeft">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#232836" Padding="20,14"
                BorderBrush="#3D4663" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="מדריך למשתמש" FontSize="22" FontWeight="Bold"
                           Foreground="#E8EAED"/>
                <TextBlock Text="SNMP SimManager v1.5" FontSize="13"
                           Foreground="#8C95A6" FlowDirection="LeftToRight"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,16">
            <StackPanel>

                <!-- Section 1: Overview -->
                <TextBlock Text="סקירה כללית" FontSize="17" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,0,0,16">
                    SNMP SimManager הוא כלי להקלטה וסימולציה של תקשורת SNMP.
                    המערכת מאפשרת להקליט את כל ה-MIB Tree מחומרות אמיתיות,
                    ואז לסמלץ אותן על המחשב שלך — כך שהתוכנה שלך ממשיכה לעבוד
                    גם בלי חומרה פיזית.
                </TextBlock>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section 2: Devices Tab -->
                <TextBlock Text="לשונית DEVICES — ניהול מכשירים" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>הוספת מכשיר:</Bold> הזן שם, כתובת IP, פורט (161), גרסת SNMP (V2c/V3)
                        ו-Community String. לחץ "Add Device".
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>SNMPv3:</Bold> אם נבחר V3, יש למלא גם Username, Auth Protocol (MD5/SHA),
                        Auth Password, Privacy Protocol (DES/AES) ו-Privacy Password.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>מחיקה:</Bold> בחר מכשיר בטבלה ולחץ "Remove Selected".
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        Auto-Discovery (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>סריקת רשת:</Bold> הזן Subnet (למשל 192.168.1.0), טווח כתובות (1-254)
                        ו-Community String. לחץ "Scan" — המערכת תסרוק את כל הכתובות ותמצא
                        מכשירי SNMP אוטומטית. סמן את המכשירים שרוצים ולחץ "Add Selected Devices".
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        Export / Import (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Export:</Bold> מייצא את כל המכשירים + הקלטות Walk/Sessions + קבצי MIB
                        כקובץ .snmpsim אחד. אידיאלי לשיתוף בין מחשבים, גיבוי, או העברת סביבה לעמית.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Import:</Bold> טוען קובץ .snmpsim ומוסיף את כל המכשירים + הנתונים + קבצי MIB למערכת.
                        קבצי MIB משויכים אוטומטית למכשירים המתאימים.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section 3: Recorder Tab -->
                <TextBlock Text="לשונית RECORDER — הקלטה וקליטת SNMP" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>SNMP GET:</Bold> הזן OID בשדה ולחץ GET לקבלת ערך בודד מהמכשיר.
                        ניתן להזין מספר OIDs מופרדים בפסיק.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>SNMP SET:</Bold> הזן OID, ערך חדש וסוג נתון (Integer32, OctetString וכו'),
                        ולחץ SET לשינוי ערך במכשיר.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Test Connection:</Bold> בדיקה מהירה — שולח GET ל-sysDescr (1.3.6.1.2.1.1.1.0).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>SNMP Walk:</Bold> סריקה מלאה של כל ה-MIB Tree של המכשיר.
                        הנתונים נשמרים אוטומטית לקובץ JSON ומשמשים את הסימולטור.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Trap Listener:</Bold> מאזין לפורט UDP 162 לקליטת Traps מהמכשיר.
                        לחץ "Save Traps" לשמירתם.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        הקלטת Session (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Record Session:</Bold> מבצע Walk חוזר כל X שניות (ברירת מחדל: 10).
                        כל Walk שומר "Frame" עם חותמת זמן — כך נלכד בדיוק איך ערכי OID
                        משתנים לאורך זמן (למשל: מוני תעבורה, CPU, סטטוס ממשקים).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Stop &amp; Save:</Bold> עוצר את ההקלטה ושומר את כל ה-Frames לקובץ session.json.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Interval:</Bold> ניתן לשנות את תדירות הדגימה (בשניות) לפני ההקלטה.
                        ערך נמוך = דיוק גבוה יותר, אבל קובץ גדול יותר.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section 4: Simulator Tab -->
                <TextBlock Text="לשונית SIMULATOR — סימולציה" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>הפעלת סימולטור:</Bold> בחר מכשיר בלשונית DEVICES, הגדר Listen IP
                        (ברירת מחדל: 0.0.0.0 = כל הכתובות) ו-Port (ברירת מחדל: 10161)
                        ולחץ "Start for Selected".
                        הסימולטור יקשיב על הכתובת והפורט ויענה לבקשות GET/GETNEXT/GETBULK/SET.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Listen IP:</Bold> 0.0.0.0 מאזין על כל כתובות הרשת של המחשב.
                        ניתן להגדיר כתובת ספציפית כדי להאזין רק על ממשק רשת מסוים.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>SNMP Query:</Bold> בחר סימולטור פעיל, הזן OID ולחץ:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • GET — קבלת ערך בודד
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • SET — שינוי ערך (הזן ערך וסוג נתון)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • WALK — סריקת כל ה-OIDs תחת הענף שנבחר
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Live Traffic:</Bold> מציג בזמן אמת את כל הבקשות שהגיעו לסימולטור.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Play Traps:</Bold> שליחת Traps שנקלטו אל Trap Target שהוגדר.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        הזרקת Session — Injection (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Inject Session:</Bold> טוען הקלטת Session ששמרת בטאב Recorder
                        ומנגן אותה על הסימולטור הפעיל. ערכי ה-OID מתעדכנים דינמית
                        לפי ה-Timeline המקורי — המכשיר הווירטואלי מתנהג בדיוק כמו האמיתי!
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>לולאה:</Bold> ההקלטה רצה בלולאה — כשנגמרת, חוזרת להתחלה.
                        כך ניתן לבדוק תוכנות ניטור לאורך זמן.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Stop Inject:</Bold> עוצר את ה-Playback. הערכים נשארים על הערך האחרון שהוזרק.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,12,0,0">
                        <Bold>Double-Click:</Bold> לחיצה כפולה על שורה ב-Live Traffic או בטבלת Query Results
                        מעתיקה את ה-OID לשדה ומבצעת GET אוטומטית.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: MIB Browser -->
                <TextBlock Text="לשונית MIB BROWSER — צפייה בעץ MIB" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>עץ MIB:</Bold> מציג את כל ה-OIDs של המכשיר הנבחר כעץ היררכי.
                        Scalars מוצגים כעלים עם ערך ישיר. טבלאות מוצגות כ-Table → Entry → Columns
                        (כל עמודה מציגה מספר instances). OIDs עם ערכים מוצגים בירוק.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>חיפוש:</Bold> הקלד OID, שם, או ערך בשדה החיפוש — העץ יסומן
                        וטבלת התוצאות תסונן בהתאם.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>תצוגה כפולה:</Bold> מעבר בין Tree View ל-Flat View (טבלה שטוחה).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Expand / Collapse All:</Bold> פתיחה או סגירה של כל ענפי העץ. לחיצה ימנית
                        על ענף בודד מציגה אפשרות ל-Expand/Collapse All Children.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>שמות MIB:</Bold> OIDs מוכרים (system, interfaces, וכו') מוצגים עם שמות קריאים.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        טעינת קבצי MIB (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Load MIB:</Bold> לחץ "Load MIB" כדי לטעון קבצי MIB מהדיסק (פורמטים: .mib, .txt, .my).
                        קבצי MIB מכילים את שמות ה-OIDs של חומרות ספציפיות (למשל: Cisco, HP, Juniper).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Per-Device:</Bold> קבצי MIB משויכים למכשיר הנבחר — כל מכשיר יכול לקבל
                        MIB-ים שונים. כשעוברים בין מכשירים, ה-MIB-ים נטענים אוטומטית.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>תלויות בין MIBs:</Bold> ניתן לטעון מספר קבצי MIB ביחד — המערכת תפתור
                        תלויות צולבות אוטומטית. למשל, אם IF-MIB משתמש בשמות מ-SNMPv2-SMI,
                        טען את שניהם ושמות ה-OIDs ייפתרו במלואם.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>הסרה:</Bold> ליד כל MIB טעון מופיע כפתור X להסרתו מהמכשיר.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Export/Import:</Bold> כשמייצאים Package, כל קבצי ה-MIB המשויכים
                        נכללים בקובץ .snmpsim ומשוחזרים אוטומטית בייבוא.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        Export Panel JSON (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Export Panel JSON:</Bold> מייצא קובץ JSON מפורט ומובנה לבניית ממשק UI אוטומטי.
                        ה-JSON מחולק ל-Scalars (שדות בודדים כמו sysName) ו-Tables (טבלאות עם שורות ועמודות
                        כמו ifTable) — מוכן להצגה ישירה כטפסים וגריד.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>שימוש:</Bold> טען קבצי MIB למכשיר ← לחץ "Export Panel JSON" ← בחר מיקום שמירה.
                        הקובץ מוכן לשליחה דרך SignalR לאפליקציית Angular/Web לבניית פאנל ניהול מותאם אישית.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>מבנה ה-JSON:</Bold>
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • <Bold>Scalars:</Bold> כל שדה כולל OID, שם, תיאור, סוג גישה, סוג קלט, ערך נוכחי ומגבלות
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>Tables:</Bold> כל טבלה כוללת עמודות (columns) ושורות (rows) עם ערכים לכל תא,
                        עמודת תיאור (label) ופענוח ערכי enum
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>מיפוי סוגי קלט:</Bold>
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • INTEGER עם enum → בחירה מתוך רשימה (dropdown)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Enum עם 2 ערכים (0/1) + הרשאת כתיבה → מתג ON/OFF (toggle)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Enum סטטוס read-only (ok/fail/alarm...) → נורית LED צבעונית (status-led)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • INTEGER עם טווח → שדה מספרי עם min/max
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • OCTET STRING → שדה טקסט עם maxLength
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Counter/Gauge/TimeTicks → תצוגת סטטוס (read-only)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • IpAddress → שדה כתובת IP
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>חד-חד ערכיות:</Bold> כל שדה ב-JSON ממופה ל-OID ייחודי אחד — ניתן לבצע
                        GET ו-SET ישירות דרך ה-OID של כל שדה.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: MIB Panel UI -->
                <TextBlock Text="MIB Panel UI — ממשק דשבורד אנגולר" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>MIB Panel Viewer:</Bold> אפליקציית Angular מקצועית שמציגה את ה-Panel JSON
                        כדשבורד ויזואלי מרשים. טען את ה-JSON שיוצא מ-Export Panel JSON — האפליקציה
                        מזהה אוטומטית את סוגי השדות ובונה ממשק מותאם.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        כרטיס מכשיר (Device Card)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        בראש הדף מוצג כרטיס זיהוי המכשיר עם שם, דגם, גרסת firmware,
                        מספר סריאלי, כתובת IP, כתובת MAC וזמן פעילות (uptime) — כולם מזוהים
                        אוטומטית מתוך השדות הסטנדרטיים ב-MIB.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        אזור ניטור (Monitoring)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        שדות סטטוס, counters ו-gauges מוצגים ככרטיסים צבעוניים עם פס שמאלי:
                        ירוק = תקין, אדום = תקלה, כתום = אזהרה, כחול = מונה. ערכי enum מוצגים
                        כ-pills עם צבע תואם. מונים מעוצבים בפורמט קריא (1.2M, 3.5G).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>נוריות סטטוס (Status LED):</Bold> שדות enum read-only עם ערכים סטנדרטיים
                        (ok, fail, alarm, on, off, up, down...) מוצגים כנוריות LED צבעוניות:
                        ◉ ירוק = תקין, ◉ כתום = אזהרה, ◉ אדום (מהבהב) = תקלה, ◉ אפור = כבוי.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        אזור הגדרות (Configuration)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        שדות עם הרשאת כתיבה (read-write / read-create) מוצגים כטופס עריכה.
                        לחיצה על ערך או על אייקון העט פותחת שדה עריכה מותאם:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • Enum → תפריט בחירה (dropdown)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Toggle (0/1) → מתג ON/OFF
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Number → שדה מספרי עם min/max
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • IP → שדה כתובת IP
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Text → שדה טקסט חופשי
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        לחיצה על "Save" שולחת את הערך החדש. הודעת אישור/שגיאה מופיעה כ-toast.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        טבלאות (Tables)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        טבלאות SNMP (כמו ifTable, sdUserTable) מוצגות כגריד עם עמודות ושורות.
                        תאים הניתנים לעריכה מסומנים — לחיצה כפולה פותחת שדה עריכה בתוך התא.
                        שמות עמודות מוצגים בפורמט קריא ללא OID.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        מאפייני מערכת (System Properties)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        בתחתית הדף מוצג פוטר מעוצב עם נתונים סטנדרטיים מה-MIB, מחולק ל-3 קטגוריות:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • <Bold>Identity</Bold> (סגול) — שם, תיאור, דגם, סריאלי, מספר slot
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>System</Bold> (ירוק) — firmware, hardware, uptime, contact, location
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>Network</Bold> (כחול) — IP, MAC, gateway, subnet, DNS, פורט SNMP, community
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        חלון צד (Side Panel)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        לחיצה על "Open Panel" פותחת חלון צד שנגלל מימין עם כל המידע —
                        מודולים, ניטור, הגדרות, טבלאות ומאפייני מערכת — בתצוגה קומפקטית.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        טעינת קובץ
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        ניתן לטעון קובץ Panel JSON בשתי דרכים:
                        לחיצה על "Load JSON" בסרגל העליון, או גרירת קובץ .json ישירות לאזור הראשי.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        הפעלה
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        האפליקציה נמצאת בתיקיית mib-panel-ui/. להפעלה:
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,6,0,0"
                               FlowDirection="LeftToRight">
                        cd mib-panel-ui
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,2,0,0"
                               FlowDirection="LeftToRight">
                        npm install
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,2,0,0"
                               FlowDirection="LeftToRight">
                        npx ng serve --open
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: SignalR Communication -->
                <TextBlock Text="SignalR — תקשורת בזמן אמת" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>חיבור דו-כיווני:</Bold> המערכת משתמשת ב-SignalR 2.0 לתקשורת בזמן אמת
                        בין אפליקציית WPF לאפליקציית Angular. שרת SignalR רץ על פורט 5050
                        ומאפשר שליחה וקבלה של נתונים בשני הכיוונים.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        הפעלת שרת SignalR
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        השרת מופעל אוטומטית עם הפעלת האפליקציה. סטטוס החיבור מוצג
                        בלשונית Simulator (ירוק = פעיל, אדום = כבוי). כתובת ברירת מחדל:
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,6,0,0"
                               FlowDirection="LeftToRight">
                        http://localhost:5050/signalr
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        WPF → Angular (Push)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        כאשר הסימולטור פעיל, כל תעבורת SNMP (GET/SET/WALK/TRAP) נשלחת
                        אוטומטית ל-Angular. אפליקציית הפאנל מתעדכנת בזמן אמת — ערכים
                        משתנים ישירות על המסך ללא רענון.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        Angular → WPF (SET)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        כאשר המשתמש עורך ערך בפאנל Angular ולוחץ "Save", הערך נשלח
                        דרך SignalR ל-WPF שמבצע SNMP SET על הסימולטור. תוצאת ה-SET
                        חוזרת כ-Toast בממשק Angular.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        בחירת מכשיר מרחוק
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        כאשר Angular מחובר, תפריט "Select Device" מציג את כל המכשירים
                        עם Walk. בחירת מכשיר טוענת את ה-Panel Schema ומתחילה עדכון בזמן אמת.
                        כפתור Refresh מבצע סנכרון מלא של כל הערכים.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: IDD Panel -->
                <TextBlock Text="IDD Panel — תמיכה במכשירים שאינם SNMP" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>מהו IDD?</Bold> Interface Design Document — פרוטוקול תקשורת מותאם אישית
                        עם חומרה (לא SNMP). המערכת תומכת בהצגה ועריכה של שדות IDD
                        באותו ממשק פאנל כמו SNMP, באמצעות אותו פורמט JSON.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        מבנה JSON של IDD
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        קובץ IDD Panel JSON משתמש באותו פורמט כמו MIB Panel, אבל עם שדות שונים:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • <Bold>oid</Bold> — מזהה ייחודי (טקסטואלי, למשל "idd.net.ip" — לא מספרי)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>inputType</Bold> — סוג שדה: text, number, enum, toggle, ip
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>isWritable</Bold> — true/false לפי הרשאת שדה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • <Bold>currentValue</Bold> — ערך נוכחי
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,8,0,0">
                        <Bold>דוגמה:</Bold> קובץ דוגמה נמצא בתיקייה:
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,6,0,0"
                               FlowDirection="LeftToRight">
                        mib-panel-ui/public/assets/examples/idd-panel-example.json
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        עריכת שדות IDD
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        שדות IDD הניתנים לעריכה (isWritable=true) מתנהגים בדיוק כמו שדות SNMP —
                        לחיצה על הערך פותחת שדה עריכה מותאם. הערך נשלח דרך SignalR
                        לאפליקציית WPF שמטפלת בתקשורת מול החומרה.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        הבדלים מ-SNMP
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • מזהה השדה (oid) מתחיל באות ולא בספרה → זיהוי אוטומטי כ-IDD
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • ללא סיומת .0 אוטומטית (כמו ב-SNMP scalars)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • פקודת SET עוברת דרך SendIddSet (לא SendSet)
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: IDD Simulator -->
                <TextBlock Text="סימולציית IDD — עדכון שדות מ-WPF" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>IDD Simulate:</Bold> אזור ייעודי בלשונית Simulator לסימולציית שדות IDD.
                        מאפשר טעינת קובץ IDD Panel JSON, בחירת שדה, שינוי ערך ושליחת עדכון
                        לאפליקציית Angular בזמן אמת.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        שלבי השימוש
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">1.</Bold>  לחץ "Load IDD JSON" ובחר קובץ Panel JSON (MIB או IDD)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">2.</Bold>  רשימת השדות נטענת ל-ComboBox עם שם המודול, שם השדה ומזהה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">3.</Bold>  בחר שדה מהרשימה — המזהה והערך הנוכחי ממולאים אוטומטית
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">4.</Bold>  שנה את הערך בשדה Value
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">5.</Bold>  לחץ "Broadcast" — הערך נשלח דרך SignalR ל-Angular
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,8,0,0">
                        <Bold>תוצאה:</Bold> הפאנל ב-Angular מתעדכן מיידית — ניתן לראות את הערך
                        החדש בשדה המתאים ללא רענון דף.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#8C95A6" FontSize="12" LineHeight="20" Margin="0,8,0,0">
                        טיפ: ניתן לטעון את אותו קובץ JSON גם ב-Angular (Load JSON) וגם ב-WPF
                        (Load IDD JSON) — כך אפשר לסמלץ שינויים ולראות את התוצאה בזמן אמת.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: IDD Editor -->
                <TextBlock Text="לשונית IDD EDITOR — עורך שדות IDD" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>IDD Editor:</Bold> כלי ליצירה ועריכה של הגדרות שדות IDD (מכשירים שאינם SNMP).
                        מאפשר הוספה, עריכה, מחיקה ושמירה ל-JSON — בדיוק כמו MIB Browser עבור מכשירי SNMP.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        מבנה המסך
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>כותרת:</Bold> שם מכשיר, כתובת IP, מספר שדות, וכפתורי פעולה (Load, Save, Register).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>צד שמאל:</Bold> טבלת שדות — מציגה ID, שם, סוג, קבוצה, הרשאות (RO/RW), ערך ברירת מחדל ויחידות.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>צד ימין:</Bold> טופס עריכה — כל מאפייני השדה: ID, שם, קבוצה, סוג, תיאור,
                        הרשאות כתיבה, ערך ברירת מחדל, יחידות, Min/Max, MaxLength, ואפשרויות (enum/toggle).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        פעולות
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">+ Add Field:</Bold>  מלא את הטופס (ID ושם חובה) ולחץ "Add Field" להוספת שדה חדש
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Update:</Bold>  בחר שדה קיים, שנה ערכים בטופס ולחץ "Update"
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Delete:</Bold>  בחר שדה ולחץ "Delete Selected" למחיקה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Duplicate:</Bold>  שכפל שדה קיים עם סיומת ".copy"
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Move Up/Down:</Bold>  שנה סדר שדות ברשימה
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        שמירה וטעינה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Quick Save:</Bold>  שמירה מהירה ל-Data/schemas/{שם מכשיר}.json
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Save JSON As...:</Bold>  שמירה לקובץ לפי בחירת המשתמש
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Load JSON:</Bold>  טעינת שדות מקובץ JSON קיים (MIB Browser או IDD)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Load from Device:</Bold>  טעינת שדות IDD ממכשיר שנבחר בלשונית DEVICES
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">Register as Device:</Bold>  שמירה + רישום כמכשיר IDD חדש ברשימת DEVICES
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        11 סוגי שדות נתמכים
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="24" FontFamily="Cascadia Code,Consolas"
                               FlowDirection="LeftToRight" HorizontalAlignment="Left">
text       — Free text input
number     — Integer with Min/Max range
enum       — Dropdown (requires Options)
toggle     — ON/OFF switch (0 and 1)
status-led — LED indicator (read-only)
gauge      — Numeric gauge with Units
counter    — Incrementing counter (read-only)
timeticks  — Duration (Xd Yh Zm Ss)
ip         — IP address (X.X.X.X)
oid        — OID path string
bits       — Bit flags (hex string)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#8C95A6" FontSize="12" LineHeight="20" Margin="0,10,0,0">
                        טיפ: שדה Options (לסוגי enum ו-toggle) מוגדר כטקסט — שורה לכל ערך בפורמט Label=value.
                        לדוגמה: Disabled=0 ובשורה הבאה Enabled=1.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#8C95A6" FontSize="12" LineHeight="20" Margin="0,4,0,0">
                        טיפ: קובץ ה-JSON שנשמר זהה לפורמט של MIB Browser Export — ניתן לטעון אותו גם ב-Angular.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: Scenario Builder -->
                <TextBlock Text="לשונית SCENARIOS — בניית תרחישים" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Scenario Builder:</Bold> בנה תרחישי תקלה וסימולציה ידנית.
                        הגדר אירועים לאורך ציר זמן — כל אירוע משנה ערך OID בזמן מוגדר.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Presets:</Bold> תבניות מוכנות — "Interface Down/Up" ו-"CPU Spike"
                        מוסיפות אירועים מוכנים מראש.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Play:</Bold> הפעל את התרחיש על כל הסימולטורים הפעילים.
                        האירועים מופעלים לפי ציר הזמן שהוגדר. ניתן להפעיל בלולאה.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Save / Load:</Bold> שמור תרחישים כקבצי .scenario.json ושתף עם אחרים.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>דוגמה:</Bold> T+0s ממשק יורד → T+30s ממשק עולה → T+60s CPU קופץ ל-95%
                        → T+120s CPU חוזר ל-15%. מערכת ניטור חיצונית תראה את השינויים בזמן אמת.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: Monitor Tab -->
                <TextBlock Text="לשונית MONITOR — ניטור תעבורה" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Network Monitor:</Bold> מסך ויזואלי בזמן אמת המציג את התעבורה בין
                        קליינטים/הזרקות לסימולטורים. מתעדכן אוטומטית עם כל בקשת SNMP.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>טופולוגיה:</Bold> צד שמאל מציג מקורות תעבורה (קליינטים בירוק,
                        הזרקות בכתום). צד ימין מציג סימולטורים פעילים. במרכז — חיצי תעבורה.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Address Mapping:</Bold> טבלת מיפוי כתובות — מציגה לכל סימולטור
                        את הכתובת המקורית של החומרה ואת כתובת הסימולטור.
                        השתמש בטבלה הזו כדי לדעת מה להגדיר במערכת הניהול החיצונית.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Traffic Log:</Bold> טבלת לוג מפורטת עם זמן, מקור, מכשיר, פעולה, OID וערך.
                        מוגבלת ל-500 שורות אחרונות.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Clear:</Bold> מנקה את כל הנתונים — תעבורה, קליינטים ומוני בקשות.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section 6: Demo Mode -->
                <TextBlock Text="מצב הדגמה (Demo Mode)" FontSize="15" FontWeight="Bold"
                           Foreground="#FFAB00" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>Load Demo Data:</Bold> יוצר 4 מכשירי הדגמה עם נתוני SNMP Walk מוכנים:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,4,0,0">
                        • Demo-Switch-Floor2 — סוויץ' עם 26 פורטים (~170 OIDs)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Demo-Router-Main — ראוטר עם 4 ממשקים, BGP, טבלת ניתוב
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Demo-AP-Lobby — נקודת גישה WiFi עם 2.4/5GHz
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" Margin="24,2,0,0">
                        • Super-Device-Lab — מכשיר מקיף עם MIB מותאם: 43 scalars, 5 טבלאות,
                        כל סוגי הגישה, enums, DIO, חיישנים, משתמשים, VLANs ו-Traps
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,6,0,0">
                        <Bold>Start All Simulators:</Bold> מפעיל סימולטורים לכל המכשירים
                        (פורטים 10161-10164). ניתן מיד לבצע GET/SET/WALK דרך הממשק.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#FFAB00" FontSize="14" FontWeight="Bold" LineHeight="22" Margin="0,12,0,4">
                        Start &amp; Inject All (חדש!)
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        <Bold>▶ Start &amp; Inject All:</Bold> בלחיצה אחת — מפעיל סימולטור לכל מכשיר
                        ומזריק אוטומטית את ה-Session הראשון הזמין. אידיאלי לתרחיש שבו רוצים
                        להפעיל מספר מכשירים בבת אחת עם ניגון הקלטות.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section 6: Quick Start -->
                <TextBlock Text="התחלה מהירה — Demo" FontSize="15" FontWeight="Bold"
                           Foreground="#57D9A3" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">1.</Bold>  לחץ "Load Demo Data" לטעינת מכשירי הדגמה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">2.</Bold>  לחץ "Start All Simulators" להפעלת הסימולציה
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">3.</Bold>  עבור ללשונית SIMULATOR ובחר סימולטור
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">4.</Bold>  הזן OID ולחץ GET — תקבל ערך מהסימולטור!
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="תהליך מלא — הקלטה + סימולציה דינמית" FontSize="15" FontWeight="Bold"
                           Foreground="#57D9A3" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">1.</Bold>  הוסף מכשיר אמיתי בלשונית DEVICES
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">2.</Bold>  בטאב RECORDER — לחץ "Start SNMP Walk" להקלטת snapshot
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">3.</Bold>  לחץ "Record Session" — ההקלטה תתפוס שינויים לאורך זמן
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">4.</Bold>  המתן מספר דקות ולחץ "Stop &amp; Save"
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">5.</Bold>  בטאב SIMULATOR — הפעל סימולטור ולחץ "Inject Session"
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">6.</Bold>  המכשיר הווירטואלי כעת מתנהג בדיוק כמו האמיתי!
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="תרחיש מלא — החלפת מספר חומרות בסימולטורים" FontSize="15" FontWeight="Bold"
                           Foreground="#57D9A3" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,16">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22" Margin="0,0,0,8">
                        מערכת ניהול מדברת עם 5 חומרות בכתובות שונות.
                        אתה רוצה לנגן הקלטות במקומן:
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">1.</Bold>  הוסף את כל 5 המכשירים בלשונית DEVICES (עם IPs אמיתיים)
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">2.</Bold>  לכל מכשיר — בצע Walk + Record Session בטאב RECORDER
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">3.</Bold>  לחץ "▶ Start &amp; Inject All" — כל הסימולטורים עולים עם הזרקות
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">4.</Bold>  עבור ללשונית MONITOR — ראה טבלת Address Mapping
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">5.</Bold>  שנה במערכת הניהול את כתובות המכשירים לכתובות הסימולטורים
                    </TextBlock>
                    <TextBlock Foreground="#CDD1D8" FontSize="13" LineHeight="24">
                        <Bold Foreground="#57D9A3">6.</Bold>  מערכת הניהול מקבלת תשובות כאילו מדברת עם חומרה אמיתית!
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="#8C95A6" FontSize="12" LineHeight="20" Margin="0,8,0,0">
                        טיפ: בטאב MONITOR הטבלה מראה בדיוק איזו כתובת מקורית מוחלפת באיזו
                        כתובת סימולטור — אין צורך לזכור בעל פה.
                    </TextBlock>
                </StackPanel>

                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>

                <!-- Section: Common OIDs -->
                <TextBlock Text="OIDs שימושיים" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <Grid Margin="16,0,0,16" FlowDirection="LeftToRight">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                        <RowDefinition/><RowDefinition/><RowDefinition/>
                        <RowDefinition/><RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="1.3.6.1.2.1.1.1.0"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="sysDescr — תיאור המכשיר"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="1.3.6.1.2.1.1.3.0"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="sysUpTime — זמן פעילות"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="1.3.6.1.2.1.1.5.0"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="sysName — שם המכשיר"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="1.3.6.1.2.1.2.1.0"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="ifNumber — מספר ממשקים"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="1.3.6.1.2.1.2.2.1.2"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="ifDescr — תיאור ממשקים"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="1.3.6.1.2.1.2.2.1.8"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Text="ifOperStatus — סטטוס ממשק (1=up, 2=down)"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="1.3.6.1.2.1.2.2.1.10"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="ifInOctets — בתים נכנסים"
                               Foreground="#CDD1D8" FontSize="12"/>

                    <TextBlock Grid.Row="7" Grid.Column="0" Text="1.3.6.1.2.1.2.2.1.16"
                               Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="ifOutOctets — בתים יוצאים"
                               Foreground="#CDD1D8" FontSize="12"/>
                </Grid>

                <!-- Section 8: Data Storage -->
                <Border Height="1" Background="#3D4663" Margin="0,4,0,16"/>
                <TextBlock Text="אחסון נתונים" FontSize="15" FontWeight="Bold"
                           Foreground="#4C9AFF" Margin="0,0,0,8"/>
                <StackPanel Margin="16,0,0,8">
                    <TextBlock TextWrapping="Wrap" Foreground="#CDD1D8" FontSize="13" LineHeight="22">
                        כל הנתונים נשמרים בתיקיית Data/ בפורמט JSON:
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,6,0,0"
                               FlowDirection="LeftToRight">
                        Data/profiles.json          — רשימת מכשירים
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,2,0,0"
                               FlowDirection="LeftToRight">
                        Data/{DeviceName}/walk.json  — נתוני Walk
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,2,0,0"
                               FlowDirection="LeftToRight">
                        Data/{DeviceName}/traps.json   — Traps שנקלטו
                    </TextBlock>
                    <TextBlock Foreground="#8BB8D0" FontFamily="Consolas" FontSize="12" Margin="24,2,0,0"
                               FlowDirection="LeftToRight">
                        Data/{DeviceName}/sessions/*.json — הקלטות Session (כל הקלטה בקובץ נפרד)
                    </TextBlock>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#232836" Padding="20,10"
                BorderBrush="#3D4663" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock Text="SNMP SimManager v1.5" Foreground="#8C95A6" FontSize="12"
                           VerticalAlignment="Center" FlowDirection="LeftToRight"/>
                <Button Content="סגור" DockPanel.Dock="Left" HorizontalAlignment="Left"
                        Click="CloseButton_Click" MinWidth="80" Style="{StaticResource AccentButton}"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
