<UserControl x:Class="SNMPSimMgr.Views.MibBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SNMPSimMgr.ViewModels"
             xmlns:views="clr-namespace:SNMPSimMgr.Views"
             xmlns:helpers="clr-namespace:SNMPSimMgr.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  helpers:ScrollHelper.BubbleMouseWheel="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="250"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}" Padding="0">
            <StackPanel>
                <!-- Row 1: Title + action buttons (always visible) -->
                <DockPanel Margin="14,10">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1A2A3A" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                            <TextBlock Text="&#x1F333;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MIB Browser" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                                <Run Text="{Binding LoadedDeviceName, Mode=OneWay}"/>
                                <Run Text=" — "/>
                                <Run Text="{Binding TotalOids, Mode=OneWay}"/>
                                <Run Text=" OIDs"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <!-- Load MIB button -->
                        <Button Content="Load MIB" Command="{Binding LoadMibFileCommand}"
                                Style="{StaticResource AccentButton}" Padding="10,5" FontSize="11"
                                IsEnabled="{Binding HasDevice}"/>
                        <!-- Export Panel JSON button -->
                        <Button Content="Export Panel JSON" Command="{Binding ExportPanelSchemaCommand}"
                                Padding="10,5" FontSize="11" Margin="4,0,0,0"
                                IsEnabled="{Binding MibCount, Converter={StaticResource BoolToVisConverter}}"/>
                        <!-- MIB count badge -->
                        <Border Background="#2A3A2A" CornerRadius="10" Padding="8,4" Margin="4,0"
                                BorderBrush="{StaticResource AccentGreenBrush}" BorderThickness="1"
                                Visibility="{Binding MibCount, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}">
                                <Run Text="{Binding MibCount, Mode=OneWay}"/>
                                <Run Text=" MIB defs"/>
                            </TextBlock>
                        </Border>
                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,4"/>
                        <!-- Refresh button (Panel mode) -->
                        <Button Content="&#x1F504; Refresh" Command="{Binding PanelRefreshCommand}"
                                Padding="10,5" FontSize="11" Style="{StaticResource AccentButton}"
                                Visibility="{Binding ShowPanel, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="Expand All" Command="{Binding ExpandAllCommand}"
                                Padding="10,5" FontSize="11"
                                Visibility="{Binding ShowTree, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="Collapse All" Command="{Binding CollapseAllCommand}"
                                Padding="10,5" FontSize="11"
                                Visibility="{Binding ShowTree, Converter={StaticResource BoolToVisConverter}}"/>
                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,4"
                                Visibility="{Binding ShowTree, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Command="{Binding ToggleViewCommand}" Padding="10,5" FontSize="11">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <!-- Default (Tree mode): show Flat View button -->
                                    <Setter Property="Content" Value="&#x1F4CB; Flat View"/>
                                    <Style.Triggers>
                                        <!-- Flat mode (not tree, not panel): show Panel View button -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ShowTree}" Value="False"/>
                                                <Condition Binding="{Binding ShowPanel}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Content" Value="&#x1F4CA; Panel View"/>
                                        </MultiDataTrigger>
                                        <!-- Panel mode: show Tree View button -->
                                        <DataTrigger Binding="{Binding ShowPanel}" Value="True">
                                            <Setter Property="Content" Value="&#x1F333; Tree View"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Row 2: Loaded MIB files — scrollable chips strip + Unload All -->
                <Border Background="#151925" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="10,5" Visibility="{Binding MibCount, Converter={StaticResource BoolToVisConverter}}">
                    <DockPanel>
                        <!-- Unload All button — pinned right -->
                        <Button DockPanel.Dock="Right" Content="Unload All" Command="{Binding UnloadAllMibsCommand}"
                                Style="{StaticResource DangerButton}" Padding="8,3" FontSize="10"
                                VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <!-- Scrollable chips -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      Padding="0">
                            <ItemsControl ItemsSource="{Binding LoadedMibFiles}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E2233" CornerRadius="10" Padding="6,3" Margin="2,0"
                                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding}" FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="X" FontSize="8" Padding="4,1" Margin="4,0,0,0"
                                                        Style="{StaticResource DangerButton}"
                                                        Command="{Binding DataContext.RemoveMibCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Search bar -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}" Padding="12,8">
            <StackPanel>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#x1F50D;" FontSize="16" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,0">
                        <Run Text="{Binding FlatRecords.Count, Mode=OneWay}"/>
                        <Run Text=" results"/>
                    </TextBlock>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"/>
                </DockPanel>
                <TextBlock Text="{Binding MibStatus}" FontSize="10" Margin="0,4,0,0"
                           Foreground="{StaticResource AccentGreenBrush}"
                           Visibility="{Binding MibStatus, Converter={StaticResource BoolToVisConverter}}"/>
                <TextBlock Text="{Binding ExportStatus}" FontSize="10" Margin="0,2,0,0"
                           Foreground="{StaticResource AccentBlueBrush}"
                           Visibility="{Binding ExportStatus, Converter={StaticResource BoolToVisConverter}}"/>
                <TextBlock Text="{Binding PanelStatus}" FontSize="10" Margin="0,2,0,0"
                           Foreground="{StaticResource AccentOrangeBrush}"
                           Visibility="{Binding PanelStatus, Converter={StaticResource BoolToVisConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Tree View -->
        <Border Grid.Row="2" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Margin="0,0,0,4">
            <Grid>
                <!-- OID Tree -->
                <TreeView x:Name="mibTree" ItemsSource="{Binding RootNodes}"
                          BorderThickness="0"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding ShowTree, Converter={StaticResource BoolToVisConverter}}">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding" Value="2,1"/>
                            <Setter Property="Tag"
                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                     RelativeSource={RelativeSource Self}}"
                                                 MinWidth="200">
                                        <!-- GET: always visible -->
                                        <MenuItem Command="{Binding PlacementTarget.Tag.ContextGetCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="GET" FontWeight="Bold" Width="50"
                                                               Foreground="{StaticResource AccentGreenBrush}"/>
                                                    <TextBlock Text="Read value" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <!-- SET: only for writable OIDs -->
                                        <MenuItem Command="{Binding PlacementTarget.Tag.ContextSetCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding IsWritable,
                                                      Converter={StaticResource BoolToVisConverter}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="SET" FontWeight="Bold" Width="50"
                                                               Foreground="{StaticResource AccentOrangeBrush}"/>
                                                    <TextBlock Text="Write value" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <!-- WALK: only for branch nodes -->
                                        <MenuItem Command="{Binding PlacementTarget.Tag.ContextWalkCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}">
                                            <MenuItem.Header>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="WALK" FontWeight="Bold" Width="50"
                                                               Foreground="{StaticResource AccentBlueBrush}"/>
                                                    <TextBlock Text="Walk subtree" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <Separator Visibility="{Binding HasChildren,
                                                       Converter={StaticResource BoolToVisConverter}}"/>
                                        <!-- Expand/Collapse: only for branch nodes -->
                                        <MenuItem Command="{Binding PlacementTarget.Tag.ExpandAllChildrenCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}">
                                            <MenuItem.Header>
                                                <TextBlock Text="Expand All Children"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem Command="{Binding PlacementTarget.Tag.CollapseAllChildrenCommand,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Visibility="{Binding HasChildren,
                                                      Converter={StaticResource BoolToVisConverter}}">
                                            <MenuItem.Header>
                                                <TextBlock Text="Collapse All Children"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <!-- Name -->
                                <Run FontWeight="SemiBold">
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            <Setter Property="Text" Value="{Binding DisplayName, Mode=OneWay}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLeaf}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                                <!-- OID -->
                                <Run Text="  " FontSize="2"/>
                                <Run Text="{Binding Oid, Mode=OneWay}" FontSize="10"
                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                <!-- = Value (leaf only, via binding) -->
                                <Run Text="{Binding ValueDisplay, Mode=OneWay}" FontSize="11"
                                     FontFamily="Cascadia Code,Consolas,Courier New"
                                     Foreground="{StaticResource AccentBlueBrush}"/>
                            </TextBlock>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- Flat DataGrid view (visible when NOT tree AND NOT panel) -->
                <DataGrid ItemsSource="{Binding FlatRecords}" AutoGenerateColumns="False"
                          IsReadOnly="True" BorderThickness="0"
                          FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowTree}" Value="False"/>
                                        <Condition Binding="{Binding ShowPanel}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="2*"/>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="2*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ValueType}" Width="100"/>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="3*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Panel View -->
                <views:MibPanelView DataContext="{Binding}"
                                    Visibility="{Binding ShowPanel, Converter={StaticResource BoolToVisConverter}}"/>

                <!-- Empty state -->
                <TextBlock Text="Select a device in DEVICES tab to browse its MIB data"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Opacity="0.6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding TotalOids}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>
        <!-- Query Results Panel (Row 3) -->
        <Border Grid.Row="3" Style="{StaticResource SectionBorder}" Margin="0,4,0,0"
                MaxHeight="200"
                Visibility="{Binding TreeQueryResults.Count, Converter={StaticResource BoolToVisConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Query Results" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Background="#2A3A2A" CornerRadius="8" Padding="6,2" Margin="8,0,0,0"
                                BorderBrush="{StaticResource AccentGreenBrush}" BorderThickness="1">
                            <TextBlock FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}">
                                <Run Text="{Binding TreeQueryResults.Count, Mode=OneWay}"/>
                            </TextBlock>
                        </Border>
                        <TextBlock Text="{Binding TreeQueryStatus}" FontSize="10" Margin="10,0,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button DockPanel.Dock="Right" Content="Clear"
                            Command="{Binding ClearTreeQueryResultsCommand}"
                            HorizontalAlignment="Right" Padding="8,2" FontSize="10"/>
                </DockPanel>
                <!-- Results grid -->
                <DataGrid Grid.Row="1" ItemsSource="{Binding TreeQueryResults}"
                          AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0"
                          FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11"
                          HeadersVisibility="Column" CanUserResizeRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="60"/>
                        <DataGridTextColumn Header="OP" Binding="{Binding Operation}" Width="50"/>
                        <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="2*"/>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ValueType}" Width="90"/>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
