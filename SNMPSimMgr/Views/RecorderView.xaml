<UserControl x:Class="SNMPSimMgr.Views.RecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SNMPSimMgr.Models">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Device Info Header -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Icon + Title + Target -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Recorder icon -->
                    <Border Background="#2A1A1A" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWalking}" Value="True">
                                        <Setter Property="Background" Value="#1A3A2A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsRecordingSession}" Value="True">
                                        <Setter Property="Background" Value="#3A1A1A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#x25CF;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsWalking}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsRecordingSession}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="SNMP Recorder" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Target:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding SelectedDevice.Name, FallbackValue='(select a device)', Mode=OneWay}"
                                       FontWeight="SemiBold" Foreground="{StaticResource AccentBlueBrush}" FontSize="12"/>
                            <TextBlock Text="{Binding SelectedDevice.IpAddress, FallbackValue='', Mode=OneWay, StringFormat=' ({0})'}"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                       Visibility="{Binding SelectedDevice, Converter={StaticResource BoolToVisConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Status pills -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Walk status pill -->
                    <Border CornerRadius="10" Padding="10,5" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A3042"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsWalking}" Value="True">
                                        <Setter Property="Background" Value="#1A3A2A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource TextSecondaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsWalking}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource AccentGreenBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding WalkStatus}" FontSize="11"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- OID count pill -->
                    <Border Background="{StaticResource AccentBlueBrush}" CornerRadius="10"
                            Padding="10,5" Margin="0,0,8,0">
                        <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                            <Run Text="{Binding OidCount, Mode=OneWay}"/>
                            <Run Text=" OIDs"/>
                        </TextBlock>
                    </Border>

                    <!-- Session recording pill (visible only when recording) -->
                    <Border CornerRadius="10" Padding="10,5" Background="#3A1A1A"
                            Visibility="{Binding IsRecordingSession, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentRedBrush}" Margin="0,0,6,0"/>
                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentRedBrush}">
                                <Run Text="REC"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextPrimaryBrush}" Margin="6,0,0,0">
                                <Run Text="{Binding SessionFrameCount, Mode=OneWay}"/>
                                <Run Text=" frames"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SNMP GET / SET -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="SNMP GET / SET" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Unified Grid for GET/SET fields -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: OID + GET + Test Connection -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="OID:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding QueryOid, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                             VerticalContentAlignment="Center"/>
                    <StackPanel Grid.Row="0" Grid.Column="4" Orientation="Horizontal">
                        <Button Content="GET"
                                Command="{Binding SnmpGetCommand}"
                                Style="{StaticResource AccentButton}" Margin="6,0,0,0" Padding="10,6"
                                IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="Test Connection"
                                Command="{Binding TestConnectionCommand}" Margin="6,0,0,0" Padding="10,6"/>
                    </StackPanel>

                    <!-- Row 2: Value + Type + SET + Clear -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Value:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding SetValue, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Type:"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Row="2" Grid.Column="3"
                              ItemsSource="{x:Static models:SnmpTypeNames.All}"
                              SelectedItem="{Binding SetValueType}"/>
                    <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Horizontal">
                        <Button Content="SET"
                                Command="{Binding SnmpSetCommand}"
                                Style="{StaticResource DangerButton}" Margin="6,0,0,0" Padding="10,6"
                                IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="Clear"
                                Command="{Binding ClearResultsCommand}" Margin="6,0,0,0" Padding="10,6"/>
                    </StackPanel>
                </Grid>

                <!-- Results DataGrid -->
                <DataGrid ItemsSource="{Binding GetResults}" AutoGenerateColumns="False"
                          IsReadOnly="True" MaxHeight="200"
                          FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="80"/>
                        <DataGridTextColumn Header="OP" Binding="{Binding Operation}" Width="70"/>
                        <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="3*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ValueType}" Width="120"/>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
            <WrapPanel>
                <Button Content="Start SNMP Walk" Command="{Binding StartWalkCommand}"
                        Style="{StaticResource SuccessButton}"
                        IsEnabled="{Binding IsWalking, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Stop Walk" Command="{Binding StopWalkCommand}"
                        Style="{StaticResource DangerButton}"
                        IsEnabled="{Binding IsWalking}"/>

                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,2" Height="28"/>

                <Button Command="{Binding ToggleTrapListenerCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="Start Trap Listener"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsListeningTraps}" Value="True">
                                    <Setter Property="Content" Value="Stop Trap Listener"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Save Traps" Command="{Binding SaveCapturedTrapsCommand}"/>

                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,2" Height="28"/>

                <!-- Session Recording -->
                <TextBlock Text="Name:" VerticalAlignment="Center" Margin="0,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}" Width="130" Margin="4,0,6,0"
                         VerticalContentAlignment="Center" FontSize="12"
                         ToolTip="Session name (auto-generated if empty)"/>
                <Button Content="Record" Command="{Binding StartSessionRecordingCommand}"
                        Style="{StaticResource AccentButton}" Padding="10,6" Margin="0"
                        IsEnabled="{Binding IsRecordingSession, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Stop &amp; Save" Command="{Binding StopSessionRecordingCommand}"
                        Style="{StaticResource DangerButton}" Padding="10,6" Margin="0"
                        IsEnabled="{Binding IsRecordingSession}"/>
                <TextBlock Text="Interval:" VerticalAlignment="Center" Margin="8,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <TextBox Text="{Binding SessionInterval}" Width="40" Margin="4,0,0,0"
                         VerticalContentAlignment="Center"
                         FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"/>
                <TextBlock Text="s" VerticalAlignment="Center" Margin="2,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <Border Background="{StaticResource AccentBlueBrush}" CornerRadius="8"
                        Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsRecordingSession, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                        <Run Text="{Binding SessionFrameCount, Mode=OneWay}"/>
                        <Run Text=" frames"/>
                    </TextBlock>
                </Border>

                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,2" Height="28"/>

                <!-- Session List -->
                <TextBlock Text="Sessions:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                <ComboBox ItemsSource="{Binding SessionList}" SelectedItem="{Binding SelectedSessionName}"
                          Width="160" Margin="4,0,0,0" FontSize="12"/>
                <Button Content="Delete" Command="{Binding DeleteSessionCommand}"
                        Style="{StaticResource DangerButton}" Padding="8,4" Margin="4,0,0,0"
                        FontSize="11"/>
            </WrapPanel>
        </Border>

        <!-- Log -->
        <Border Grid.Row="3" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Margin="0,0,0,4">
            <ListBox ItemsSource="{Binding LogEntries}"
                     FontFamily="Cascadia Code,Consolas,Courier New" FontSize="12"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="NoWrap" Foreground="#8BB8D0"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <!-- Captured Traps -->
        <Expander Grid.Row="4" IsExpanded="False" Margin="0,4,0,0"
                  Foreground="{StaticResource TextPrimaryBrush}">
            <Expander.Header>
                <TextBlock Text="Captured Traps" FontWeight="SemiBold" FontSize="13"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Expander.Header>
            <DataGrid ItemsSource="{Binding CapturedTraps}" AutoGenerateColumns="False"
                      IsReadOnly="True" MaxHeight="200" Margin="0,6,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="TIME" Binding="{Binding Timestamp, StringFormat=HH:mm:ss}" Width="80"/>
                    <DataGridTextColumn Header="SOURCE" Binding="{Binding SourceIp}" Width="130"/>
                    <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="*"/>
                    <DataGridTextColumn Header="BINDINGS" Binding="{Binding VariableBindings.Count}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Expander>
    </Grid>
</UserControl>
