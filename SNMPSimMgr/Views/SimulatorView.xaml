<UserControl x:Class="SNMPSimMgr.Views.SimulatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SNMPSimMgr.Models">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controls -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="SNMP Simulator Engine" Style="{StaticResource HeaderText}" Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Listen IP:Port + buttons -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Listen on:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <TextBox Text="{Binding SimulatorListenIp}"
                                 Width="110" VerticalContentAlignment="Center"
                                 FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                                 ToolTip="Listen IP (0.0.0.0 = all interfaces, or specific IP)"/>
                        <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding SimulatorPort}" Width="70"
                                 VerticalContentAlignment="Center"
                                 FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                                 ToolTip="UDP port number"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="5" Orientation="Horizontal">
                        <Button Content="Start Selected"
                                Command="{Binding StartSimulatorCommand}"
                                Style="{StaticResource SuccessButton}" Margin="0" Padding="10,6"/>
                        <Button Content="Stop Selected"
                                Command="{Binding StopSimulatorCommand}"
                                Style="{StaticResource DangerButton}" Margin="6,0,0,0" Padding="10,6"/>
                        <Button Content="Stop All"
                                Command="{Binding StopAllCommand}" Margin="6,0,0,0" Padding="10,6"/>
                    </StackPanel>

                    <!-- Row 2: Trap Target + Play button -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Trap Target:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding TrapTargetIp}"
                             VerticalContentAlignment="Center"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text=":"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="2" Grid.Column="3"
                             Text="{Binding TrapTargetPort}"
                             VerticalContentAlignment="Center"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"/>
                    <Button Grid.Row="2" Grid.Column="5" Content="Play Recorded Traps"
                            Command="{Binding PlayTrapsCommand}"
                            Style="{StaticResource AccentButton}" Margin="0" Padding="10,6"/>

                    <!-- Row 4: Session Injection -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Injection:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3"
                                Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox ItemsSource="{Binding SessionList}" SelectedItem="{Binding SelectedSessionName}"
                                  Width="170" FontSize="12" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding InjectionStatus}" VerticalAlignment="Center"
                                   Foreground="{StaticResource AccentBlueBrush}" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Grid.Row="4" Grid.Column="5" Orientation="Horizontal">
                        <Button Content="Inject"
                                Command="{Binding InjectSessionCommand}"
                                Style="{StaticResource AccentButton}" Margin="0" Padding="10,6"
                                IsEnabled="{Binding IsInjecting, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="Stop Inject"
                                Command="{Binding StopInjectionCommand}"
                                Style="{StaticResource DangerButton}" Margin="6,0,0,0" Padding="10,6"
                                IsEnabled="{Binding IsInjecting}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Active Simulators -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Active Simulators" FontWeight="SemiBold" FontSize="13"/>
                    <Border Background="{StaticResource AccentBlueBrush}" CornerRadius="8"
                            Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ActiveSimulators.Count, FallbackValue=0}"
                                   FontSize="11" FontWeight="Bold" Foreground="White"/>
                    </Border>
                </StackPanel>
                <DataGrid ItemsSource="{Binding ActiveSimulators}" AutoGenerateColumns="False"
                          IsReadOnly="True" MaxHeight="100">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DEVICE" Binding="{Binding DeviceName}" Width="*"/>
                        <DataGridTextColumn Header="LISTEN IP" Binding="{Binding ListenIp}" Width="120"/>
                        <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="70"/>
                        <DataGridTextColumn Header="OIDs" Binding="{Binding OidCount}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- SNMP Query (GET / SET / WALK) -->
        <Border Grid.Row="2" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock Text="SNMP Query (GET / SET / WALK)" FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,10" Foreground="{StaticResource TextPrimaryBrush}"/>

                <!-- Unified Grid for all query fields -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="70"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="32"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Simulator -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Simulator:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                              ItemsSource="{Binding ActiveSimulators}"
                              SelectedItem="{Binding SelectedSimulator}"
                              DisplayMemberPath="DeviceName"/>

                    <!-- Row 2: OID + GET + WALK -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="OID:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
                             Text="{Binding QueryOid, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Row="2" Grid.Column="4" Content="GET"
                            Command="{Binding QueryGetCommand}"
                            Style="{StaticResource AccentButton}" Margin="6,0,0,0"
                            IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Grid.Row="2" Grid.Column="5" Content="WALK"
                            Command="{Binding QueryWalkCommand}"
                            Style="{StaticResource SuccessButton}" Margin="6,0,0,0"
                            IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"/>

                    <!-- Row 4: Value + Type + SET + Clear -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Value:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding SetValue, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code,Consolas,Courier New" FontSize="13"
                             VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Type:"
                               VerticalAlignment="Center" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Row="4" Grid.Column="3"
                              ItemsSource="{x:Static models:SnmpTypeNames.All}"
                              SelectedItem="{Binding SetValueType}"/>
                    <Button Grid.Row="4" Grid.Column="4" Content="SET"
                            Command="{Binding QuerySetCommand}"
                            Style="{StaticResource DangerButton}" Margin="6,0,0,0"
                            IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Grid.Row="4" Grid.Column="5" Content="Clear"
                            Command="{Binding ClearQueryResultsCommand}" Margin="6,0,0,0"/>
                </Grid>

                <!-- Results DataGrid (double-click row → OID + auto GET) -->
                <DataGrid ItemsSource="{Binding QueryResults}" AutoGenerateColumns="False"
                          IsReadOnly="True" MaxHeight="220"
                          FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11"
                          MouseDoubleClick="QueryResults_DoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TIME" Binding="{Binding Time}" Width="80"/>
                        <DataGridTextColumn Header="OP" Binding="{Binding Operation}" Width="70"/>
                        <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="3*"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ValueType}" Width="120"/>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Live Traffic + System Log side by side -->
        <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Live Traffic header -->
            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Live Traffic" FontWeight="SemiBold" FontSize="13"/>
                <Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}"
                         Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Live Traffic list (double-click row → OID + auto GET) -->
            <Border Grid.Row="1" Grid.Column="0" CornerRadius="6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ListBox x:Name="TrafficListBox"
                         ItemsSource="{Binding TrafficLog}"
                         FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#8BB8D0"/>
                            <EventSetter Event="MouseDoubleClick" Handler="TrafficLog_DoubleClick"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" Foreground="#8BB8D0"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- System Log header -->
            <TextBlock Grid.Row="0" Grid.Column="2" Text="System Log"
                       FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>
            <!-- System Log list -->
            <Border Grid.Row="1" Grid.Column="2" CornerRadius="6"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ListBox x:Name="SystemLogListBox"
                         ItemsSource="{Binding LogEntries}"
                         FontFamily="Cascadia Code,Consolas,Courier New" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="NoWrap" Foreground="#8BB8D0"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
