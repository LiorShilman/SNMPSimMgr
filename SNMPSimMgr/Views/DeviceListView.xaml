<UserControl x:Class="SNMPSimMgr.Views.DeviceListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:SNMPSimMgr.Models">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Add Device Form -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource HeaderText}">
                            <Setter Property="Text" Value="Add New Device"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Text" Value="Edit Device"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Margin="2,0,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="IP Address" Margin="2,0,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding NewIp, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Port" Margin="2,0,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="2"
                             Text="{Binding NewPort, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Version" Margin="2,0,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox Grid.Row="1" Grid.Column="3"
                              SelectedItem="{Binding NewVersion}"
                              ItemsSource="{Binding Source={x:Static models:SnmpVersionOptionValues.All}}"
                              Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Community" Margin="2,0,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="4"
                             Text="{Binding NewCommunity, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,2,6"/>

                    <!-- SNMPv3 fields -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="v3 Username" Margin="2,4,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Grid.Row="3" Grid.Column="0"
                             Text="{Binding NewV3User, UpdateSourceTrigger=PropertyChanged}" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="v3 Auth Password" Margin="2,4,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="AuthPassBox" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Auth" Margin="2,4,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox Grid.Row="3" Grid.Column="2"
                              SelectedItem="{Binding NewV3AuthProto}"
                              ItemsSource="{Binding Source={x:Static models:AuthProtocolValues.All}}"
                              Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="v3 Priv Password" Margin="2,4,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <PasswordBox Grid.Row="3" Grid.Column="3" x:Name="PrivPassBox" Margin="2,0,2,6"/>

                    <TextBlock Grid.Row="2" Grid.Column="4" Text="Priv" Margin="2,4,2,2"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ComboBox Grid.Row="3" Grid.Column="4"
                              SelectedItem="{Binding NewV3PrivProto}"
                              ItemsSource="{Binding Source={x:Static models:PrivProtocolValues.All}}"
                              Margin="2,0,2,6"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="2,6,2,0">
                    <!-- Add mode -->
                    <Button Content="+ Add Device" Command="{Binding AddDeviceCommand}"
                            Style="{StaticResource AccentButton}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Invert}"/>
                    <!-- Edit mode -->
                    <Button Content="Save Changes" Command="{Binding SaveEditCommand}"
                            Style="{StaticResource SuccessButton}" Margin="0,0,6,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                            Margin="0,0,6,0"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"/>
                    <Button Content="+ New Device" Command="{Binding CancelEditCommand}"
                            Style="{StaticResource AccentButton}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Auto-Discovery -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" Text="&#x1F50D; Auto-Discovery" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Scan" Command="{Binding StartDiscoveryCommand}"
                                Padding="10,4" FontSize="11">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Stop" Command="{Binding StopDiscoveryCommand}"
                                Style="{StaticResource DangerButton}" Padding="10,4" FontSize="11"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"/>
                    </StackPanel>
                </DockPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Subnet:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding ScanSubnet, UpdateSourceTrigger=PropertyChanged}"
                             Width="120" FontSize="11"/>
                    <TextBlock Text="Range:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,6,0"/>
                    <TextBox Text="{Binding ScanStart}" Width="45" FontSize="11"/>
                    <TextBlock Text="-" VerticalAlignment="Center" Margin="4,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding ScanEnd}" Width="45" FontSize="11"/>
                    <TextBlock Text="Community:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,6,0"/>
                    <TextBox Text="{Binding ScanCommunity, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" FontSize="11"/>
                    <TextBlock Text="{Binding ScanStatus}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0"/>
                </StackPanel>
                <!-- Progress bar -->
                <ProgressBar Value="{Binding ScanProgress}" Maximum="{Binding ScanTotal}" Height="4"
                             Margin="0,6,0,0"
                             Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisConverter}}"/>
                <!-- Discovery results -->
                <ItemsControl ItemsSource="{Binding DiscoveredDevices}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E2233" CornerRadius="4" Padding="8,4" Margin="0,2">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding SysDescr}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="10" VerticalAlignment="Center"
                                               MaxWidth="400" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IpAddress}"
                                                   FontFamily="Cascadia Code,Consolas,Courier New"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentGreenBrush}"/>
                                        <TextBlock Text=" — " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding SysName}" FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <!-- Add selected button -->
                <Button Content="+ Add Selected Devices" Command="{Binding AddDiscoveredDevicesCommand}"
                        Style="{StaticResource SuccessButton}" Padding="10,4" FontSize="11"
                        HorizontalAlignment="Left" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <!-- Device List -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Devices}"
                  SelectedItem="{Binding SelectedDevice}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  Margin="0,4,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="IP ADDRESS" Binding="{Binding IpAddress}" Width="140"/>
                <DataGridTextColumn Header="PORT" Binding="{Binding Port}" Width="65"/>
                <DataGridTextColumn Header="VERSION" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="COMMUNITY" Binding="{Binding Community}" Width="100"/>
                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Actions -->
        <DockPanel Grid.Row="3" Margin="0,8,0,0">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="Remove Selected" Command="{Binding RemoveDeviceCommand}"
                        Style="{StaticResource DangerButton}"/>
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,2" Height="28"/>
                <Button Content="+ Add Test Devices" Command="{Binding AddTestDevicesCommand}"
                        Style="{StaticResource SuccessButton}" Padding="10,6" Margin="0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding PackageStatus}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="&#x1F4E6; Export" Command="{Binding ExportPackageCommand}"
                        ToolTip="Export all devices + data as .snmpsim package"
                        Padding="10,6" Margin="0,0,4,0"/>
                <Button Content="&#x1F4E5; Import" Command="{Binding ImportPackageCommand}"
                        ToolTip="Import devices from .snmpsim package"
                        Style="{StaticResource AccentButton}" Padding="10,6"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
