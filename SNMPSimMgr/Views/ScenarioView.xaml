<UserControl x:Class="SNMPSimMgr.Views.ScenarioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:SNMPSimMgr.Helpers">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  helpers:ScrollHelper.BubbleMouseWheel="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#2A1A1A" CornerRadius="8" Width="40" Height="40" Margin="0,0,14,0">
                        <TextBlock Text="&#x26A1;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Scenario Builder" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Simulate faults, load changes, and device behavior"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="Load" Command="{Binding LoadScenarioCommand}" Padding="10,5" FontSize="11"/>
                    <Button Content="Save" Command="{Binding SaveScenarioCommand}" Padding="10,5" FontSize="11"
                            Margin="4,0"/>
                    <Border Width="1" Background="{StaticResource BorderBrush}" Margin="6,4"/>
                    <!-- Play / Stop -->
                    <Button Command="{Binding PlayScenarioCommand}" Padding="12,5" FontSize="11"
                            Style="{StaticResource SuccessButton}"
                            Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisConverter}, ConverterParameter=Inverse}">
                        <Button.Content>
                            <TextBlock>
                                <Run Text="&#x25B6;"/> <Run Text="Play"/>
                            </TextBlock>
                        </Button.Content>
                    </Button>
                    <Button Content="&#x25FC; Stop" Command="{Binding StopScenarioCommand}"
                            Style="{StaticResource DangerButton}" Padding="12,5" FontSize="11"
                            Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisConverter}}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Add Event + Presets -->
        <Border Grid.Row="1" Style="{StaticResource SectionBorder}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock DockPanel.Dock="Left" Text="Scenario:" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox DockPanel.Dock="Left" Text="{Binding ScenarioName, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" FontSize="11" Margin="0,0,12,0"/>
                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding ScenarioLoop}" Content="Loop"
                              Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding PlayStatus}" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource AccentGreenBrush}"/>
                </DockPanel>

                <!-- New event form -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="T+" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox Text="{Binding NewDelay}" Width="45" FontSize="11" Margin="2,0,4,0"/>
                    <TextBlock Text="s" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Label:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding NewLabel, UpdateSourceTrigger=PropertyChanged}" Width="140" FontSize="11"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="OID:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding NewOid, UpdateSourceTrigger=PropertyChanged}" Width="180" FontSize="11"
                             FontFamily="Cascadia Code,Consolas,Courier New" Margin="0,0,8,0"/>
                    <TextBlock Text="Value:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Text="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}" Width="100" FontSize="11"
                             Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding ValueTypes}" SelectedItem="{Binding NewValueType}"
                              Width="100" FontSize="11" Margin="0,0,8,0"/>
                    <Button Content="+ Add" Command="{Binding AddEventCommand}"
                            Style="{StaticResource AccentButton}" Padding="10,4" FontSize="11"/>
                </StackPanel>

                <!-- Presets -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Presets:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Button Content="&#x1F534; Interface Down/Up" Command="{Binding AddPresetInterfaceDownCommand}"
                            Padding="8,3" FontSize="10" Margin="0,0,4,0"/>
                    <Button Content="&#x1F525; CPU Spike" Command="{Binding AddPresetHighCpuCommand}"
                            Padding="8,3" FontSize="10" Margin="0,0,4,0"/>
                    <Button Content="Clear All" Command="{Binding ClearEventsCommand}"
                            Style="{StaticResource DangerButton}" Padding="8,3" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Timeline / Event list -->
        <Border Grid.Row="2" CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" Margin="0,0,0,4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="14,10,14,6">
                    <TextBlock Text="Timeline" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0">
                        <Run Text="{Binding Events.Count, Mode=OneWay}"/>
                        <Run Text=" events"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="{StaticResource AccentGreenBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"
                               Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVisConverter}}">
                        <Run Text="T+"/>
                        <Run Text="{Binding ElapsedSeconds, Mode=OneWay}"/>
                        <Run Text="s"/>
                    </TextBlock>
                </StackPanel>
                <DataGrid ItemsSource="{Binding Events}" AutoGenerateColumns="False"
                          IsReadOnly="True" BorderThickness="0" FontSize="11"
                          CanUserResizeRows="False">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Padding" Value="4,2"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="TIME" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="Bold" VerticalAlignment="Center">
                                        <Run Text="T+"/>
                                        <Run Text="{Binding DelaySeconds, Mode=OneWay}"/>
                                        <Run Text="s"/>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="EVENT" Binding="{Binding Label}" Width="200"/>
                        <DataGridTextColumn Header="OID" Binding="{Binding Oid}" Width="220">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Cascadia Code,Consolas,Courier New"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="120"/>
                        <DataGridTextColumn Header="TYPE" Binding="{Binding ValueType}" Width="100"/>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X" FontSize="9" Padding="4,1"
                                            Command="{Binding DataContext.RemoveEventCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButton}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#161A26" CornerRadius="4" Padding="10,6">
            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="Tip: Start a simulator first, then play the scenario. Events modify OID values in all active simulators."/>
            </TextBlock>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
